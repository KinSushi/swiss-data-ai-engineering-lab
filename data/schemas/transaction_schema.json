{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Transaction",
  "type": "object",
  "required": [
    "transaction_id",
    "client_id",
    "amount",
    "currency",
    "timestamp"
  ],
  "properties": {
    "transaction_id": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "enum": [
        "CHF",
        "EUR",
        "USD",
        "GBP"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
